From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2026
From: Security Research <security@example.com>
Date: Tue May 28 2026
Subject: [PATCH] Hardening: add bounds checking in script copy functions

Add runtime assertion that destination buffer is large enough
before writing escaped capture data. This provides defense-in-depth
should a similar state-mismatch bug be introduced in the future.

diff --git a/src/http/ngx_http_script.c b/src/http/ngx_http_script.c
index 4b4164245..a9b7c53d2 100644
--- a/src/http/ngx_http_script.c
+++ b/src/http/ngx_http_script.c
@@ -840,6 +840,7 @@ ngx_http_script_copy_capture_code(ngx_http_script_engine_t *e)
     u_char                    *p;
     ngx_int_t                  n;
     ngx_uint_t                 i;
+    size_t                     remaining;
 
     r = e->request;
 
@@ -860,12 +861,17 @@ ngx_http_script_copy_capture_code(ngx_http_script_engine_t *e)
     if ((e->is_args || e->quote)
         && (e->request->quoted_uri || e->request->plus_in_uri))
     {
+        remaining = r->pool->d.end - r->pool->d.last;
         p = r->captures_data;
 
         n = (ngx_int_t) *e->ip;
 
         e->ip += sizeof(ngx_int_t);
 
+        if (ngx_escape_uri(NULL, &p[cap[n]], cap[n + 1] - cap[n],
+                           NGX_ESCAPE_ARGS) > remaining) {
+            ngx_log_error(NGX_LOG_ERR, r->connection->log, 0,
+                          "script copy capture: destination buffer too small");
+            return;
+        }
+
         e->pos = (u_char *) ngx_escape_uri(pos, &p[cap[n]],
                                            cap[n + 1] - cap[n],
                                            NGX_ESCAPE_ARGS);
-- 
